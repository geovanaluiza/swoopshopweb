# SwoopShop environment

# Shopify Storefront API (pickup-only headless checkout)
# 1. Shopify admin → Settings → Apps and sales channels → Develop apps
# 2. Create app → Configure Storefront API scopes:
#      unauthenticated_read_product_listings
#      unauthenticated_write_checkouts
#      unauthenticated_read_checkouts
# 3. Install app → copy the Storefront API public access token
# 4. Enable Local Pickup: Settings → Shipping and delivery → Local pickup
#    → Student Center – Pecota location (disable shipping rates for pickup-only)
NUXT_PUBLIC_SHOPIFY_DOMAIN=
NUXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
